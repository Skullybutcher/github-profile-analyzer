{
  "name": "github-profile-analyzer",
  "version": "1.0.0",
  "description": "GitHub Profile Analyzer - Monorepo with Next.js Frontend & Express Backend",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel dev:frontend dev:backend",
    "build": "pnpm --filter=frontend build && pnpm --filter=backend build",
    "dev:frontend": "cd frontend && pnpm dev",
    "dev:backend": "cd backend && pnpm dev",
    "build:frontend": "cd frontend && pnpm build",
    "build:backend": "cd backend && pnpm build",
    "lint": "cd frontend && pnpm lint"
  },
  "workspaces": [
    "frontend",
    "backend"
  ],
  "devDependencies": {},
  "keywords": [
    "github",
    "analyzer",
    "profile",
    "monorepo",
    "next.js",
    "express"
  ],
  "author": "",
  "license": "MIT"
}
